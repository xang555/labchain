LIGHTHOUSE_IMAGE=sigp/lighthouse:latest
LIGHTHOUSE_LOG_LEVEL=info

# Sync mode: "full" (sync from genesis) or "checkpoint" (sync from checkpoint)
SYNC_MODE=full

# Checkpoint sync URL (required when SYNC_MODE=checkpoint)
# Example: https://checkpoin.labchain.la
CHECKPOINT_SYNC_URL=https://checkpoin.labchain.la

# Execution engine endpoint the CL connects to (reth engine API).
EXECUTION_ENDPOINT=http://reth-node:8551

# Consensus HTTP and P2P exposure (override per host if running multiple nodes).
HTTP_PORT=5052
P2P_PORT=9000
TARGET_PEERS=64

# bootnode discovery for p2p.
BEACON_ENR_ADDRESS=183.182.99.171

# Discovery mode: "enr" or "libp2p"
# - enr: Use ENR-based discovery (--boot-nodes with enr:// addresses)
# - libp2p: Use libp2p multiaddr (--libp2p-addresses with /ip4/... addresses)
DISCOVERY_MODE=enr

# List of ENR bootnode for sync another CL nodes (used when DISCOVERY_MODE=enr).
# Example: BOOTNODE_ENR=enr:-N24QJrXP5TiKrnIekimyRnEHN9y_U36cHCrZ_Ff7t3xxxxxx,enr:-N24QJrXP5TiKrnIekimyRnEHN9y_U36cHCrZ_Ff7t3xxxxxx
BOOTNODE_ENR=enr:-N24QEJvtwJdpO_CSptcZdhCQi1JxMR9hPIsM6LFqXIpXmMQVdWkofRZjZGFKCAuOQ085pYGc1_puT9bGlfP31C4rC0Hh2F0dG5ldHOIAAAwAAAAAACGY2xpZW500YpMaWdodGhvdXNlhTguMS4yhGV0aDKQ5PrclmAAAAD__________4JpZIJ2NIJpcIRnQu5zhHF1aWOCIymJc2VjcDI1NmsxoQPlUD5gP495rqkrZCzoSLumOm6EEboGbnzVweWBknDjnIhzeW5jbmV0cw-DdGNwgiMog3VkcIIjKA,enr:-N24QNQObQWngpdM8Ot5HmDF6plc0F_kcfdt9vmtg4B29Od4ej7dNk-HbJVKD3_IGkNQ5-GhOl6ZF9h7afqlAA8JhX0oh2F0dG5ldHOIAAAAAAAAAAaGY2xpZW500YpMaWdodGhvdXNlhTguMC4xhGV0aDKQ5PrclmAAAAD__________4JpZIJ2NIJpcISNpGAThHF1aWOCIymJc2VjcDI1NmsxoQIm00O4WnXncWPD0mMBA23HRSaJe9Ku4VQ3riyBVk0iRIhzeW5jbmV0cw-DdGNwgiMog3VkcIIjKA,enr:-N24QOIeBMB0o4kOrG7ZOUX2dxQbNKl90uufLiNSRkhRoCsWD8iGrqzAJ6MZTteR2tB65-B-49PkOqX4RW9s2YBCYZMHh2F0dG5ldHOIBgAAAAAAAACGY2xpZW500YpMaWdodGhvdXNlhTguMS4yhGV0aDKQ5PrclmAAAAD__________4JpZIJ2NIJpcIREt-BFhHF1aWOCIymJc2VjcDI1NmsxoQLZ-Iu9_fkN-MvBdfWSvYHGxplqvF2lobxhBhL5kcYSzohzeW5jbmV0cw-DdGNwgiMog3VkcIIjKA,enr:-N24QFVg6QNhahPEER0uvRUhSbtXHRQryFUDJrbU_CbEE40oTrS5YvjQrwHLp8nc1L-oy9o7AVn1eQScjNgx_rD1A4YHh2F0dG5ldHOIAAAAwAAAAACGY2xpZW500YpMaWdodGhvdXNlhTguMS4yhGV0aDKQ5PrclmAAAAD__________4JpZIJ2NIJpcITKiY5NhHF1aWOCIymJc2VjcDI1NmsxoQISNCJ5f3UVtmwteK-qKF7sc1U3owmscscq75tR53N7g4hzeW5jbmV0cw-DdGNwgiMog3VkcIIjKA

# List of libp2p multiaddr for sync another CL nodes (used when DISCOVERY_MODE=libp2p).
# Example: BOOTNODE_LIBP2P=/ip4/141.164.96.19/tcp/9000,/ip4/192.168.1.100/tcp/9000
BOOTNODE_LIBP2P=/ip4/68.183.224.69/tcp/9000,/ip4/141.164.96.19/tcp/9000,/ip4/202.137.142.77/tcp/9000,/ip4/103.66.238.115/tcp/9000

# Extra flags appended to every lighthouse bn command (optional).
EXTRA_LIGHTHOUSE_FLAGS=
