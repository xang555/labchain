LIGHTHOUSE_IMAGE=sigp/lighthouse:latest
LIGHTHOUSE_LOG_LEVEL=info

# Sync mode: "full" (sync from genesis) or "checkpoint" (sync from checkpoint)
SYNC_MODE=full

# Checkpoint sync URL (required when SYNC_MODE=checkpoint)
# Example: https://checkpoin.labchain.la
CHECKPOINT_SYNC_URL=https://checkpoin.labchain.la

# Execution engine endpoint the CL connects to (reth engine API).
EXECUTION_ENDPOINT=http://reth-node:8551

# Consensus HTTP and P2P exposure (override per host if running multiple nodes).
HTTP_PORT=5052
P2P_PORT=9000
TARGET_PEERS=64

# bootnode discovery for p2p.
BEACON_ENR_ADDRESS=183.182.99.171

# Discovery mode: "enr" or "libp2p"
# - enr: Use ENR-based discovery (--boot-nodes with enr:// addresses)
# - libp2p: Use libp2p multiaddr (--libp2p-addresses with /ip4/... addresses)
DISCOVERY_MODE=enr

# List of ENR bootnode for sync another CL nodes (used when DISCOVERY_MODE=enr).
# Example: BOOTNODE_ENR=enr:-N24QJrXP5TiKrnIekimyRnEHN9y_U36cHCrZ_Ff7t3xxxxxx,enr:-N24QJrXP5TiKrnIekimyRnEHN9y_U36cHCrZ_Ff7t3xxxxxx
BOOTNODE_ENR=enr:-N24QLf9dpaDHd7mS0ME6Fni38bmAM4hddtSj4TiO18MZKCQDu6UJIpYYp5pqQAdjsZ74FxL5iYw3XosUZyl6w36b6oVh2F0dG5ldHOIAAwAAAAAAACGY2xpZW500YpMaWdodGhvdXNlhTguMC4xhGV0aDKQ5PrclmAAAAD__________4JpZIJ2NIJpcISNpGAThHF1aWOCIymJc2VjcDI1NmsxoQK72E4x63FT--9zyAbp5p45XMK0Zb9mYYoGtQXAyiggpIhzeW5jbmV0cw-DdGNwgiMog3VkcIIjKA,enr:-N24QBFvVZEa_KN2OEaOUcMvr4CZDtGnVx1QWsgRODV9dEHlR7HbSQjZ0sq0zsszOkz-Abm-rikLKs29DJrAny07p1sDh2F0dG5ldHOIAAAAAAAAgAGGY2xpZW500YpMaWdodGhvdXNlhTguMS4yhGV0aDKQ5PrclmAAAAD__________4JpZIJ2NIJpcIREt-BFhHF1aWOCIymJc2VjcDI1NmsxoQLdfRKsbgiNacNRaZdluwiKL6nkNlixq1Irtrav9dWWp4hzeW5jbmV0cwCDdGNwgiMog3VkcIIjKA,enr:-N24QDewpIH7uBNpj2z9M_pXl-gReNaIUktciTpneQ-cIJ7mbZtmpFNtpQyVmGq-2oHllwavpyVxu7tsmTkBJMPfm78Gh2F0dG5ldHOIAAAAAAMAAACGY2xpZW500YpMaWdodGhvdXNlhTguMS4yhGV0aDKQ5PrclmAAAAD__________4JpZIJ2NIJpcITKiY5NhHF1aWOCIymJc2VjcDI1NmsxoQNA0iDQ38OWhvN6PkCfAW2X8uIGsEoLnWxGEApEoXtZNYhzeW5jbmV0cwCDdGNwgiMog3VkcIIjKA

# List of libp2p multiaddr for sync another CL nodes (used when DISCOVERY_MODE=libp2p).
# Example: BOOTNODE_LIBP2P=/ip4/141.164.96.19/tcp/9000,/ip4/192.168.1.100/tcp/9000
BOOTNODE_LIBP2P=/ip4/68.183.224.69/tcp/9000,/ip4/141.164.96.19/tcp/9000,/ip4/202.137.142.77/tcp/9000

# Extra flags appended to every lighthouse bn command (optional).
EXTRA_LIGHTHOUSE_FLAGS=
